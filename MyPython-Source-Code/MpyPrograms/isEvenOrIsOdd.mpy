in = input("Input a number", sep='', end=' ')

while in != 'quit':
    in = int(in)
    print("Number is", sep='', end=' ')
    if in % 2 == 0:
        print("even")
    else:
        print("odd")
    print("Didn't understand", in)
    in = input("Input a number or write 'quit':", sep='', end=' ') 
print("Goodbye!")